# Copy this file to ".env" and fill in your real values.
# NEVER commit the actual ".env" file to GitHub.

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=AIAS_DB

# SMTP (email notifications) — get these from your provider (e.g. Brevo, Gmail App Password)
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=your_smtp_login_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=your_sender_email_here

# Recognition / attendance rules
RECOGNITION_THRESHOLD=0.55
LATE_CUTOFF_MINUTES=10
EARLY_LEAVE_CUTOFF_MINUTES=15
